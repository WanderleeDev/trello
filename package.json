{
  "name": "trello-clone",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:trello-clone": "node dist/trello-clone/server/server.mjs",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss}\"",
    "ngx-theme-stack:sync": "ng generate ngx-theme-stack:sync --project trello-clone",
    "prebuild": "pnpm run ngx-theme-stack:sync",
    "prestart": "pnpm run ngx-theme-stack:sync"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "dependencies": {
    "@angular/aria": "^22.0.2",
    "@angular/cdk": "~22.0.2",
    "@angular/common": "^22.0.3",
    "@angular/compiler": "^22.0.3",
    "@angular/core": "^22.0.3",
    "@angular/forms": "^22.0.3",
    "@angular/platform-browser": "^22.0.3",
    "@angular/platform-server": "^22.0.3",
    "@angular/router": "^22.0.3",
    "@angular/ssr": "^22.0.4",
    "@fortawesome/angular-fontawesome": "^5.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ngneat/error-tailor": "^5.0.1",
    "@ngrx/signals": "^21.1.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "rxjs": "~7.8.2",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^29.1.1",
    "ngx-theme-stack": "^3.8.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vitest": "^3.2.6"
  }
}